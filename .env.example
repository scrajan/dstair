# Flask Application Environment Variables
# Copy this file to .env and fill in your actual values
# NEVER commit the .env file to version control!

# REQUIRED: Secret key for session management and security
# Generate a strong random key using: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here-change-this-to-something-random

# Flask environment (development, production, testing)
FLASK_ENV=development

# Optional: Database URI (defaults to sqlite:///database.db if not set)
# DATABASE_URI=sqlite:///database.db

# REQUIRED for AI Evaluator: Groq API Key
# Get one at https://console.groq.com/
GROQ_API_KEY=your-groq-api-key-here
